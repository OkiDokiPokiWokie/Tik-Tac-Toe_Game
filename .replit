# Set the entrypoint to your main server file
entrypoint = "server.js"

# Run the npm start script defined in your package.json
run = "npm start"

# Map your internal Node.js port (3000) to the standard web port (80)
[[ports]]
localPort = 3000
externalPort = 80

[nix]
channel = "stable-23_11"
packages = [
    "nodejs-18_x",
    "psmisc"
]

[agent]
expertMode = true
